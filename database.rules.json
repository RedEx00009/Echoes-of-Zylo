{
  "rules": {
    ".read": "auth != null",
    ".write": "auth != null",

    "trailers": {
      ".indexOn": ["t", "map"],
      "$uid": {
        ".read": true,
        ".write": "auth != null && (auth.uid === $uid || !data.exists())"
      }
    },

    "mapNpcs": {
      "$map": {
        ".indexOn": ["ownerId", "t"],
        "$npcId": {
          ".read": true,
          ".write": "auth != null"
        }
      }
    },

    "raids": {
      "$map": {
        ".indexOn": ["phase", "t"],
        "$raidId": {
          ".read": true,
          ".write": "auth != null"
        }
      }
    },

    "players": {
      ".read": "auth != null",
      "$uid": {
        ".write": "auth != null && auth.uid === $uid"
      }
    },

    "partyInvites": {
      "$uid": {
        ".read": "auth != null && auth.uid === $uid",
        ".write": "auth != null"
      }
    },

    "parties": {
      ".read": "auth != null",
      "$partyId": {
        ".write": "auth != null"
      }
    },

    "partyTp": {
      "$uid": {
        ".read": "auth != null && auth.uid === $uid",
        ".write": "auth != null"
      }
    },

    "partyAccept": {
      "$uid": {
        ".read": "auth != null && auth.uid === $uid",
        ".write": "auth != null"
      }
    },

    "pvpChallenge": {
      ".read": "auth != null",
      "$challengeId": {
        ".write": "auth != null"
      }
    },

    "chat": {
      ".read": "auth != null",
      ".write": "auth != null"
    },

    "combatAnims": {
      ".read": "auth != null",
      ".write": "auth != null"
    },

    "trailerInvites": {
      "$uid": {
        ".read": "auth != null && auth.uid === $uid",
        ".write": "auth != null"
      }
    }
  }
}
